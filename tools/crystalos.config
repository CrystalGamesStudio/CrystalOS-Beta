# CrystalOS Beta - Minimalna konfiguracja jadra dla QEMU
# Uzyj: make allnoconfig && sh scripts/kconfig/merge_config.sh .config tools/crystalos.config
# Potem: make olddefconfig (uzupelni zaleznosci)

# === Architektura ===
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_PRINTK=y
CONFIG_BUG=y

# === PCI (wymagane dla virtio-pci) ===
CONFIG_PCI=y
CONFIG_PCI_GOANY=y

# === Block layer ===
CONFIG_BLOCK=y

# === Virtio (dysk, siec, grafika, konsola) ===
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_GPU=y
CONFIG_VIRTIO_CONSOLE=y

# === Systemy plikow ===
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y

# === Wyswietlanie (DRM + framebuffer + konsola) ===
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_FB=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_TTY=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# === Input (klawiatura, mysz PS/2) ===
CONFIG_INPUT=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_INPUT_MOUSE=y
CONFIG_MOUSE_PS2=y
CONFIG_SERIO=y
CONFIG_SERIO_I8042=y
CONFIG_INPUT_EVDEV=y

# === USB (dla QEMU usb-mouse/usb-kbd) ===
CONFIG_USB=y
CONFIG_USB_SUPPORT=y
CONFIG_USB_HID=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_UHCI_HCD=y

# === Siec ===
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y

# === Formaty wykonywalne ===
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# === Konsola szeregowa (do automatyzacji QEMU) ===
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# === Initramfs ===
CONFIG_BLK_DEV_INITRD=y

# === Potrzebne do bootowania z GRUB ===
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
